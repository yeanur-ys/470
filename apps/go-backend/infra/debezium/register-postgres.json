{
  "name": "ngj-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "ngj",
    "database.password": "ngj_dev_password",
    "database.dbname": "nextgenjournalism",
    "topic.prefix": "ngj",
    "plugin.name": "pgoutput",
    "slot.name": "ngj_slot",
    "publication.name": "ngj_publication",
    "table.include.list": "public.articles,public.claims,public.votes,public.appeals",
    "tombstones.on.delete": "false",
    "decimal.handling.mode": "double"
  }
}

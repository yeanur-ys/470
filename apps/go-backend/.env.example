# Only used when running `go run ./cmd/api` directly on your host machine
# (README step 3). The Docker path (`pnpm infra:up`) sets these directly in
# infra/docker-compose.yml with in-network hostnames instead of localhost —
# copying this file won't affect the containerized service.
PORT=8080
DATABASE_URL=postgres://ngj:ngj_dev_password@localhost:5432/nextgenjournalism
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ngj_dev_password
KAFKA_BROKERS=localhost:29092
JWT_SECRET=dev-secret-change-me
